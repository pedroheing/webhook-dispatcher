        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum(dispatcher_events_processed_total{outcome=\"delivered\"}) / clamp_min(sum(dispatcher_events_processed_total), 1)",
